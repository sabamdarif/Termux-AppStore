		--field="<b>───────────────────── Options ─────────────────────</b>:LBL" "" \
		--field="Embed Metadata:CHK" "${CFG[embed_metadata]}" \
		--field="Embed Thumbnail:CHK" "${CFG[embed_thumbnail]}" \
		--field="Ignore Errors (continue on failure):CHK" "TRUE" \
		--field="Use Download Archive (skip duplicates):CHK" "${CFG[use_archive]}" \
		--field="<b>──────────────── aria2c Downloader ────────────────</b>:LBL" "" \
		--field="Use aria2c for this download:CHK" "${CFG[use_aria2c]}" \
		--field="Connections per Server:NUM" "${CFG[aria2c_connections]}!1..64!1" \
		--field="<b>──────────────── SponsorBlock (YouTube) ────────────────</b>:LBL" "" \
		--field="Remove Sponsor Segments:CHK" "FALSE" \
		--field="Categories:CB" "all!all,-filler!sponsor!sponsor,intro,outro!sponsor,intro,outro,selfpromo" \
		--field="<b>───────────────────── Network ─────────────────────</b>:LBL" "" \
		--field="Sleep Between Downloads (seconds):NUM" "0!0..60!1" \
		--field="Rate Limit (e.g., 1M, 500K):" "" \
		--field="Extra yt-dlp Arguments:" "" \
		--button="Download All:0" --button="Cancel:1"); then
		return
	fi

	IFS='|' read -r \
		_l1 b_file b_urls b_path \
		_l2 b_type b_container \
		_l3 b_meta b_thumb b_ignore b_archive \
		_l4 b_use_aria2c b_aria2c_conn \
		_l5 b_sb_remove b_sb_cats \
		_l6 b_sleep b_rate b_extra \
		<<<"$result"

	if [ -z "$b_file" ] && [ -z "$b_urls" ]; then
		yad --error --title="$APP_TITLE" --text="No URLs provided." --button="OK:0"
		return
	fi
	[ -n "$b_file" ] && [ ! -f "$b_file" ] && {
		yad --error --title="$APP_TITLE" --text="File not found:\n<tt>$b_file</tt>" --button="OK:0"
		return
	}

	CFG[download_path]="$b_path"
	save_config

	CMD="yt-dlp"
	[ -n "$b_path" ] && CMD="$CMD -P \"$b_path\""

	case "$b_type" in
	"Video — Best Quality") CMD="$CMD -f \"bv*+ba/b\"" ;;
	"Video — 1080p") CMD="$CMD -f \"bv*[height<=1080]+ba/b[height<=1080]/b\"" ;;
	"Video — 720p") CMD="$CMD -f \"bv*[height<=720]+ba/b[height<=720]/b\"" ;;
	"Video — 480p") CMD="$CMD -f \"bv*[height<=480]+ba/b[height<=480]/b\"" ;;
	"Audio — Best Quality") CMD="$CMD -f bestaudio -x --audio-quality 0" ;;
	"Audio — MP3 320 kbps") CMD="$CMD -f bestaudio -x --audio-format mp3 --audio-quality 320k" ;;
	"Audio — MP3 192 kbps") CMD="$CMD -f bestaudio -x --audio-format mp3 --audio-quality 192k" ;;
	"Audio — MP3 128 kbps") CMD="$CMD -f bestaudio -x --audio-format mp3 --audio-quality 128k" ;;
	"Audio — M4A (Best)") CMD="$CMD -f bestaudio -x --audio-format m4a --audio-quality 0" ;;
	"Audio — OPUS (Best)") CMD="$CMD -f bestaudio -x --audio-format opus --audio-quality 0" ;;
	"Audio — FLAC (Lossless)") CMD="$CMD -f bestaudio -x --audio-format flac --audio-quality 0" ;;
	"Audio — AAC (Best)") CMD="$CMD -f bestaudio -x --audio-format aac --audio-quality 0" ;;
	"Audio — WAV (Lossless)") CMD="$CMD -f bestaudio -x --audio-format wav --audio-quality 0" ;;
	esac

	if [[ "$b_type" == Video* ]] && [ "$b_container" != "Auto" ]; then
		CMD="$CMD --merge-output-format $b_container"
	fi

	[ "$b_meta" = "TRUE" ] && CMD="$CMD --embed-metadata"
	if [ "$b_thumb" = "TRUE" ]; then
		CMD="$CMD --embed-thumbnail --convert-thumbnails jpg"
	fi
	[ "$b_ignore" = "TRUE" ] && CMD="$CMD -i"
	[ "$b_archive" = "TRUE" ] && CMD="$CMD --download-archive \"$ARCHIVE_FILE\""

	apply_aria2c "$b_use_aria2c" "$b_aria2c_conn"

	[ "$b_sb_remove" = "TRUE" ] && CMD="$CMD --sponsorblock-remove \"$b_sb_cats\""

	local bs="${b_sleep%%.*}"
	[ "$bs" -gt 0 ] 2>/dev/null && CMD="$CMD --sleep-interval $bs"
	[ -n "$b_rate" ] && CMD="$CMD --limit-rate $b_rate"
	[ -n "$b_extra" ] && CMD="$CMD $b_extra"

	append_common_opts

	local tmpfile=""
	if [ -n "$b_file" ] && [ -f "$b_file" ]; then
		CMD="$CMD -a \"$b_file\""
		while IFS= read -r line; do
			line=$(echo "$line" | xargs)
			[ -n "$line" ] && [[ ! "$line" =~ ^[#\;\]] ]] && add_to_history "$line"
		done <"$b_file"
	elif [ -n "$b_urls" ]; then
		tmpfile=$(mktemp "${TMPDIR:-/tmp}/ytdlp_batch_XXXXXX.txt")
		echo "$b_urls" >"$tmpfile"
		CMD="$CMD -a \"$tmpfile\""
		while IFS= read -r line; do
			line=$(echo "$line" | xargs)
			[ -n "$line" ] && [[ ! "$line" =~ ^[#\;\]] ]] && add_to_history "$line"
		done <<<"$b_urls"
	fi

	run_download "$CMD" "$b_path" "Batch Download"

	[ -n "$tmpfile" ] && rm -f "$tmpfile"
}

#===============================================================================
# QUICK DOWNLOAD
#===============================================================================

show_quick_download() {
	local h
	h=$(cap_height 430)
	local result
	if ! result=$(yad --form \
		--title="$APP_TITLE - Quick Download" \
		--window-icon="$ICON_PATH" \
		--width=620 --height="$h" \
		--separator="|" \
		--text="<b><big>  Quick Download</big></b>\nPaste a URL and go.\n" \
		--field="URL:" "" \
		--field="Save to:DIR" "${CFG[download_path]}" \
		--field="What to download:CB" "Best Video!1080p Video!720p Video!480p Video!Best Audio!MP3 (320 kbps)!MP3 (192 kbps)!MP3 (128 kbps)!M4A!OPUS!FLAC!AAC!WAV" \
		--field="Use aria2c:CHK" "${CFG[use_aria2c]}" \
		--field="aria2c Connections:NUM" "${CFG[aria2c_connections]}!1..64!1" \
		--field="Remove Sponsors (YouTube):CHK" "FALSE" \
		--button="Download:0" --button="Cancel:1"); then
		return
	fi

	IFS='|' read -r q_url q_path q_what q_use_aria2c q_aria2c_conn q_sponsor <<<"$result"
	q_url=$(echo "$q_url" | xargs)

	if [ -z "$q_url" ]; then
		yad --error --title="$APP_TITLE" --text="Please enter a URL." --button="OK:0"
		show_quick_download
		return
	fi

	CFG[download_path]="$q_path"
	save_config

	CMD="yt-dlp -P \"$q_path\""

	case "$q_what" in
	"Best Video") CMD="$CMD -f \"bv*+ba/b\"" ;;
	"1080p Video") CMD="$CMD -f \"bv*[height<=1080]+ba/b[height<=1080]/b\"" ;;
	"720p Video") CMD="$CMD -f \"bv*[height<=720]+ba/b[height<=720]/b\"" ;;
	"480p Video") CMD="$CMD -f \"bv*[height<=480]+ba/b[height<=480]/b\"" ;;
	"Best Audio") CMD="$CMD -f bestaudio -x --audio-quality 0" ;;
	"MP3 (320 kbps)") CMD="$CMD -f bestaudio -x --audio-format mp3 --audio-quality 320k" ;;
	"MP3 (192 kbps)") CMD="$CMD -f bestaudio -x --audio-format mp3 --audio-quality 192k" ;;
	"MP3 (128 kbps)") CMD="$CMD -f bestaudio -x --audio-format mp3 --audio-quality 128k" ;;
	"M4A") CMD="$CMD -f bestaudio -x --audio-format m4a --audio-quality 0" ;;
	"OPUS") CMD="$CMD -f bestaudio -x --audio-format opus --audio-quality 0" ;;
	"FLAC") CMD="$CMD -f bestaudio -x --audio-format flac --audio-quality 0" ;;
	"AAC") CMD="$CMD -f bestaudio -x --audio-format aac --audio-quality 0" ;;
	"WAV") CMD="$CMD -f bestaudio -x --audio-format wav --audio-quality 0" ;;
	esac

	CMD="$CMD --embed-metadata --embed-thumbnail --convert-thumbnails jpg"
	[ "$q_sponsor" = "TRUE" ] && CMD="$CMD --sponsorblock-remove all"

	apply_aria2c "$q_use_aria2c" "$q_aria2c_conn"

	append_common_opts

	CMD="$CMD \"$q_url\""
	add_to_history "$q_url"

	run_download "$CMD" "$q_path" "Quick Download"
}

#===============================================================================
# MAIN MENU
#===============================================================================

show_main_menu() {
	local choice
	choice=$(yad --list \
		--title="$APP_TITLE v$APP_VERSION" \
		--window-icon="$ICON_PATH" \
		--width=620 --height=390 \
		--no-click \
		--text="<b><big>$APP_TITLE</big></b>\nDownload from YouTube, Twitter, and 1000+ sites\n" \
		--column="Action" --column="Description" \
		--no-headers \
		--print-column=1 \
		"  Quick" "Paste URL, pick quality, download instantly" \
		"  Video" "Download video with full options" \
		"󰎆  Audio" "Extract audio (MP3, FLAC, OPUS, etc.)" \
		"  Batch" "Download from a URL list or file" \
		"  Formats" "List available formats for a URL" \
		"  History" "View download history" \
		"  Settings" "Configure default settings" \
		"  About" "Version info and updates" \
		--button="Go:0" --button="Exit:1")

	local ret=$?
	[ $ret -ne 0 ] && exit 0

	choice=$(echo "$choice" | tr -d '|' | xargs)

	case "$choice" in
	*Quick*) show_quick_download ;;
	*Video*) show_video_download ;;
	*Audio*) show_audio_download ;;
	*Batch*) show_batch_download ;;
	*Formats*) show_formats ;;
	*History*) show_history ;;
	*Settings*) show_settings ;;
	*About*) show_about ;;
	*) show_quick_download ;;
	esac

	show_main_menu
}

#===============================================================================
# ENTRY POINT
#===============================================================================

main() {
	check_dependencies
	load_config

	case "${1:-}" in
	--quick | -q) show_quick_download ;;
	--video | -v) show_video_download ;;
	--audio | -a) show_audio_download ;;
	--batch | -b) show_batch_download ;;
	--settings | -s) show_settings ;;
	--formats) show_formats "${2:-}" ;;
	--history) show_history ;;
	--help | -h)
		cat <<EOF
$APP_TITLE v$APP_VERSION

Usage: $(basename "$0") [OPTION] [URL]

  --quick,    -q    Quick download (simple interface)
  --video,    -v    Video download (full options)
  --audio,    -a    Audio download
  --batch,    -b    Batch download from file/list
  --settings, -s    Open settings
  --formats   URL   List formats for a URL
  --history         View download history
  --help,     -h    Show this help

Config directory: $CONFIG_DIR
EOF
		exit 0
		;;
	"") show_main_menu ;;
	*)
		if [[ "$1" =~ ^https?:// ]]; then
			show_quick_download
		else
			echo "Unknown option: $1 (use --help)"
			exit 1
		fi
		;;
	esac
}

main "$@"
