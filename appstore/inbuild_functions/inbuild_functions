LOG_FILE="$TERMUX_HOME/termux-appstore-$(date +%Y%m%d_%H%M%S).log"

function log_warn() {
	local timestamp
	timestamp=$(date '+%Y-%m-%d %H:%M:%S')
	local message="$1"
	echo "$timestamp - $message" >>"$LOG_FILE"
}

function log_error() {
	local timestamp
	timestamp=$(date '+%Y-%m-%d %H:%M:%S')
	local message="$1"
	echo "$timestamp - $message" >>"$LOG_FILE"
}

function log_debug() {
	local timestamp
	timestamp=$(date '+%Y-%m-%d %H:%M:%S')
	local message="$1"
	echo "$timestamp - $message" >>"$LOG_FILE"
}

function print_success() {
	local msg
	msg="$1"
	echo "[✓] $msg "
	log_debug "$msg"
}

function print_failed() {
	local msg
	msg="$1"
	echo "[☓] $msg "
	log_error "$msg"
	# Surface the failure to the app store UI. Under the runner's strict
	# mode (set -e) + ERR trap, returning non-zero aborts the whole script,
	# so this is fatal in practice while still composing with `cmd || ...`.
	# Mark the error as already reported so the ERR trap does not overwrite
	# this (meaningful) message with a generic one.
	__APPSTORE_ERR_REPORTED=1
	progress_error "$msg"
	return 1
}

function print_warn() {
	local msg
	msg="$1"
	echo "[!] $msg "
	log_debug "$msg"
