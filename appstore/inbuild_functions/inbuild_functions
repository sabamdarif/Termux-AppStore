function install_appimage() {
	local appimage_file_name="$1"
	local appimage_directory_name="$2"

	progress_report 10 "Setting up AppImage directory..."
	pd_check_and_delete "/opt/AppImageLauncher/$appimage_directory_name"
	pd_check_and_create_directory "/opt/AppImageLauncher/"

	progress_report 20 "Moving AppImage to install location..."
	"${SELECTED_DISTRO_TYPE}"-distro login "$SELECTED_DISTRO" -- mv "$PWD/$appimage_file_name" "/opt/AppImageLauncher/"

	progress_report 30 "Extracting AppImage contents..."
	distro_run "
cd /opt/AppImageLauncher || { print_failed 'cant find the /opt/AppImageLauncher directory'; exit 1; }
ldconfig
chmod +x '${appimage_file_name}'
APPIMAGE_EXTRACT_AND_RUN=1 ./${appimage_file_name} --appimage-extract
mv -f squashfs-root '${appimage_directory_name}'
check_and_delete '${appimage_file_name}'
"
	progress_report 80 "AppImage setup complete"
}
