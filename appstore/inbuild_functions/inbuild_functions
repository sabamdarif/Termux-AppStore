# ==================== PROGRESS SYSTEM ====================
# These helpers are the only way scripts should emit progress.
# All output goes to stderr so it never pollutes stdout.
# Tokens are only emitted when PROGRESS_ENABLED=1 (set by Python).

PROGRESS_ENABLED=${PROGRESS_ENABLED:-0}

_progress_emit() {
	[[ "$PROGRESS_ENABLED" == "1" ]] && echo "$1" >&2
}

progress_report() {
	# Usage: progress_report PERCENT "Message"
	local percent="$1"
	local message="${2:-Working...}"
	_progress_emit "__PROGRESS__ ${percent}|${message}"
}

progress_phase() {
	# Usage: progress_phase PHASE_NAME PERCENT_IN_PHASE "Message"
	local phase="$1"
	local pct="${2:-0}"
	local message="${3:-}"
	_progress_emit "__PHASE__ ${phase}|${pct}|${message}"
}

progress_done() {
	_progress_emit "__DONE__"
}

progress_error() {
	_progress_emit "__ERROR__ ${1:-Unknown error}"
}
# ==================== END PROGRESS SYSTEM ====================

# ==================== BASE FUNCTIONS ====================

function check_termux() {
	if [ ! -f /system/build.prop ]; then
		echo "[☓] Not running on Android."
		exit 1
	fi

	local tracer_pid
	tracer_pid=$(grep TracerPid "/proc/$$/status" | cut -d $'\t' -f 2)
	if [ "$tracer_pid" != "0" ]; then
		local tracer_name
		tracer_name=$(grep Name "/proc/${tracer_pid}/status" | cut -d $'\t' -f 2)
		if [ "$tracer_name" = "proot" ]; then
			echo "[☓] Must not be executed under PRoot."
			exit 1
		fi
	fi

	if [[ -z "$TERMUX_PREFIX" || "$TERMUX_PREFIX" != *"/com.termux/"* ]]; then
		echo "[☓] Please run this script inside Termux."
		exit 1
	fi
}

