function distro_run() {
	local command="$1"
	local pd_setup_content="${command}"
	local script_name="pd_setup_$$_${RANDOM}.sh"
	local script_path="$DISTRO_PATH/root/$script_name"

	create_shell_script "$script_path" "$pd_setup_content"
	"${SELECTED_DISTRO_TYPE}"-distro login "$SELECTED_DISTRO" -- /bin/bash "/root/$script_name" 2>&1 |
		while IFS= read -r line; do
			echo "$line"
			# Forward structured progress tokens from inside distro
			if [[ "$line" =~ ^(__PROGRESS__|__PHASE__|__DONE__|__ERROR__|pmstatus:) ]]; then
				echo "$line" >&2
			fi
		done
	local exit_code="${PIPESTATUS[0]}"

	# Clean up the temporary setup script
	"${SELECTED_DISTRO_TYPE}"-distro login "$SELECTED_DISTRO" -- rm -f "/root/$script_name"

	return "$exit_code"
}

function _pd_update_sys_internal() {
