function check_and_create_directory() {
	if [[ -n "$1" && ! -d "$1" ]]; then
		mkdir -p "$1" 2>/dev/null || {
			log_error "Failed to create directory: $1"
			return 1
		}
		log_debug "Created directory: $1"
	fi
}

# first check then delete
function check_and_delete() {
	local files_folders
	for files_folders in "$@"; do
		if [[ -e "$files_folders" ]]; then
			rm -rf "$files_folders" >/dev/null 2>&1 || {
				log_error "Failed to delete: $files_folders"
				continue
			}
			log_debug "Deleted: $files_folders"
		fi
	done
}

# first check then backup
function check_and_backup() {
	log_debug "Starting backup for: $*"
	# shellcheck disable=SC2206
	local files_folders_list=($@)
	local files_folders
	local date_str
	date_str=$(date +"%d-%m-%Y")

	for files_folders in "${files_folders_list[@]}"; do
		if [[ -e "$files_folders" ]]; then
			local backup="${files_folders}-${date_str}.bak"

			if [[ -e "$backup" ]]; then
				print_msg "Backup $backup already exists"
			else
				print_msg "Backing up $files_folders"
				mv "$files_folders" "$backup"
				log_debug "$files_folders $backup"
			fi
		else
			print_msg "Path $files_folders does not exist"
		fi
	done
}

# find a backup file which end with a number pattern and restore it
function check_and_restore() {
	log_debug "Starting restore for: $*"
	# shellcheck disable=SC2206
	local files_folders_list=($@)
	local files_folders

	for files_folders in "${files_folders_list[@]}"; do
		local latest_backup
		latest_backup=$(find "$(dirname "$files_folders")" -maxdepth 1 -name "$(basename "$files_folders")-[0-9][0-9]-[0-9][0-9]-[0-9][0-9][0-9][0-9].bak" 2>/dev/null | sort | tail -n 1)

		if [[ -z "$latest_backup" ]]; then
			print_msg "No backup found for $files_folders"
			continue
		fi

		if [[ -e "$files_folders" ]]; then
			print_msg "File $files_folders already exists"
		else
			print_msg "Restoring $files_folders"
			mv "$latest_backup" "$files_folders"
			log_debug "$latest_backup $files_folders"
		fi
	done
}

function download_file() {
	local dest url dest_dir dest_file
	local max_retries=5
	local attempt=1
	local successful_attempt=0

	if [[ -z "$2" ]]; then
		url="$1"
		dest="$(basename "$url")"
	else
		dest="$1"
		url="$2"
	fi

	if [[ -z "$url" ]]; then
		print_failed "No URL provided!"
		progress_error "No URL provided"
		return 1
	fi

	dest="$(realpath -m "$dest")"
	dest_dir="$(dirname "$dest")"
	dest_file="$(basename "$dest")"

	progress_phase "download" 0 "Starting download: $dest_file"

	while [[ $attempt -le $max_retries ]]; do
		print_msg "Downloading $dest_file..."
		if [[ ! -s "$dest" ]]; then
			check_and_delete "$dest"
		fi

		if command -v aria2c &>/dev/null; then
			aria2c --summary-interval=1 -x16 -s16 --retry-wait=15 --max-tries=5 \
				--dir="$dest_dir" -o "$dest_file" "$url" 2>&1 |
				while IFS= read -r line; do
					echo "$line"
					if [[ "$line" =~ \(([0-9]+)%\) ]]; then
						progress_phase "download" "ASH_REMATCH[1]}" "Downloading $dest_file (ASH_REMATCH[1]}%)"
					fi
				done
			download_status="${PIPESTATUS[0]}"
		elif command -v wget &>/dev/null; then
			wget --tries=5 --timeout=15 --retry-connrefused --progress=bar:force \
				-O "$dest" "$url" 2>&1 |
				while IFS= read -r line; do
					echo "$line"
					if [[ "$line" =~ ([0-9]+)% ]]; then
						progress_phase "download" "ASH_REMATCH[1]}" "Downloading $dest_file (ASH_REMATCH[1]}%)"
					fi
				done
			download_status="${PIPESTATUS[0]}"
		else
			curl -# -L "$url" -o "$dest"
			download_status=$?
		fi

		if [[ -f "$dest" && -s "$dest" ]]; then
			successful_attempt=$attempt
			break
		else
			print_failed "Download failed. Retrying... ($attempt/$max_retries)"
		fi
		((attempt++))
	done

	if [[ -f "$dest" ]]; then
		progress_phase "download" 100 "Download complete: $dest_file"
		if [[ $successful_attempt -eq 1 ]]; then
			print_success "File downloaded successfully."
		else
			print_success "File downloaded successfully on attempt $successful_attempt."
		fi
		return 0
	fi

	progress_error "Download failed: $dest_file"
	print_failed "Failed to download the file after $max_retries attempts. Exiting."
	return 1
}

function detact_package_manager() {
	# shellcheck disable=SC1091
	if [[ -f "/data/data/com.termux/files/usr/bin/termux-setup-package-manager" ]]; then
		source "/data/data/com.termux/files/usr/bin/termux-setup-package-manager"
	fi

	if [[ "$TERMUX_APP_PACKAGE_MANAGER" == "apt" ]]; then
		PACKAGE_MANAGER="apt"
	elif [[ "$TERMUX_APP_PACKAGE_MANAGER" == "pacman" ]]; then
		PACKAGE_MANAGER="pacman"
	else
		PACKAGE_MANAGER="pkg"
		print_failed " Could not detect your package manager, Switching To pkg "
	fi
	log_debug "Package manager: $PACKAGE_MANAGER"
}

# will check if the package is already installed or not, if it installed then reinstall and print success/failed message
function package_install_and_check {
	log_debug "Starting package installation for: $*"
	progress_phase "install" 0 "Preparing to install: $*"
	update_sys
	local packs_list
	# Properly splits on spaces
	IFS=' ' read -r -a packs_list <<<"$*"

	# pacman part
	if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
		# First, expand wildcards and count total packages
		local all_packages=()
		for package_name in "${packs_list[@]}"; do
			if [[ "$package_name" == *"*"* ]]; then
				local packages
				packages=$(pacman -Ssq 2>/dev/null | grep -E "^${package_name//\*/.*}$")
				for package in $packages; do
					all_packages+=("$package")
				done
			else
				all_packages+=("$package_name")
			fi
		done

		# Install each package
		for package in "${all_packages[@]}"; do
			local retry_count=0
			local max_retries=5
			local install_success=false

			while [[ "$retry_count" -lt "$max_retries" && "$install_success" == false ]]; do
				retry_count=$((retry_count + 1))
				check_and_delete "$TERMUX_PREFIX/var/lib/pacman/db.lck"
				print_msg "Installing Package : $package"

				pacman -S --noconfirm "$package" 2>&1 | while IFS= read -r line; do
					echo "$line"
					if [[ "${line,,}" == *"downloading"* ]]; then
						progress_phase "install" 20 "Downloading $package..."
					elif [[ "${line,,}" == *"checking"* ]]; then
						progress_phase "install" 50 "Checking $package..."
					elif [[ "${line,,}" == *"installing"* ]]; then
						progress_phase "install" 80 "Installing $package..."
					fi
				done

				# Check install status via return code of pipe (requires pipefail or check explicitly)
				# Since we piped, we check status after.

				if pacman -Qi "$package" >/dev/null 2>&1; then
					print_success "Successfully install package: $package"
					install_success=true
				else
					print_warn "Failed to install package: ${package}. Trying again... ($retry_count)"
				fi
			done
		done
	else
		#apt part
		# First, expand wildcards and count total packages
		local all_packages=()
		for package_name in "${packs_list[@]}"; do
			if [[ "$package_name" == *"*"* ]]; then
				local packages
				packages=$(apt-cache pkgnames 2>/dev/null | grep -E "^${package_name//\*/.*}$" | sort -u)
				for package in $packages; do
					all_packages+=("$package")
				done
			else
				all_packages+=("$package_name")
			fi
		done

		# Install each package
		for package in "${all_packages[@]}"; do
			local retry_count=0
			local max_retries=5
			local install_success=false

			while [[ "$retry_count" -lt "$max_retries" && "$install_success" == false ]]; do
				retry_count=$((retry_count + 1))
				print_msg "Installing package: $package"

				apt install "$package" -y 2>&1 | while IFS= read -r line; do
					echo "$line"
					if [[ "${line,,}" == *"get:"* ]]; then
						progress_phase "install" 20 "Downloading $package..."
					elif [[ "${line,,}" == *"unpacking"* ]]; then
						progress_phase "install" 50 "Unpacking $package..."
					elif [[ "${line,,}" == *"setting up"* ]]; then
						progress_phase "install" 80 "Setting up $package..."
					fi
				done

				if dpkg -s "$package" >/dev/null 2>&1; then
					print_success "Successfully install package: $package"
					install_success=true
				else
					print_warn "Failed to install package: ${package}. Trying again... ($retry_count)"
					# Only run recovery commands on failure
					dpkg --configure -a 2>/dev/null
					apt --fix-broken install -y 2>/dev/null
					apt install --fix-missing -y 2>/dev/null
				fi
			done
		done
	fi
	progress_phase "install" 100 "Package installation complete"
}

# will check the package is installed or not then remove it
function package_remove_and_check {
	log_debug "Starting package removal for: $*"
	local packs_list
	# Properly splits on spaces
	IFS=' ' read -r -a packs_list <<<"$*"

	if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
		for package_name in "${packs_list[@]}"; do
			if [[ "$package_name" == *"*"* ]]; then
				log_debug "Processing wildcard pattern: $package_name"
				local packages
				packages=$(pacman -Qsq 2>/dev/null | grep -E "^${package_name//\*/.*}$")
				if [[ -z "$packages" ]]; then
					print_success "No installed packages found matching: $package_name"
					continue
				fi
				log_debug "matched packages: $packages"
				for package in $packages; do
					local retry_count=0
					local max_retries=5
					local remove_success=false
					while [[ "$retry_count" -lt "$max_retries" && "$remove_success" == false ]]; do
						retry_count=$((retry_count + 1))
						check_and_delete "$TERMUX_PREFIX/var/lib/pacman/db.lck"
						print_msg "Removing Package : $package"

						pacman -Rnds --noconfirm "$package" 2>&1 | while IFS= read -r line; do
							echo "$line"
							if [[ "${line,,}" == *"removing"* ]]; then
								progress_phase "cleanup" 50 "Removing $package..."
							fi
						done

						if ! pacman -Qi "$package" >/dev/null 2>&1; then
							print_success "Successfully removed package: $package"
							remove_success=true
						else
							print_warn "Failed to remove package: ${package}. Trying again...($retry_count)"
						fi
					done
				done
			else
				if pacman -Qi "$package_name" >/dev/null 2>&1; then
					local retry_count=0
					local max_retries=5
					local remove_success=false
					while [[ "$retry_count" -lt "$max_retries" && "$remove_success" == false ]]; do
						retry_count=$((retry_count + 1))
						check_and_delete "$TERMUX_PREFIX/var/lib/pacman/db.lck"
						print_msg "Removing Package : $package_name"

						pacman -Rnds --noconfirm "$package_name" 2>&1 | while IFS= read -r line; do
							echo "$line"
							if [[ "${line,,}" == *"removing"* ]]; then
								progress_phase "cleanup" 50 "Removing $package_name..."
							fi
						done

						if ! pacman -Qi "$package_name" >/dev/null 2>&1; then
							print_success "Successfully removed package: $package_name"
							remove_success=true
						else
							print_warn "Failed to remove package: ${package_name}. Trying again... ($retry_count)"
						fi
					done
				else
					print_success "Package $package_name is not installed."
				fi
			fi
		done
	else
		for package_name in "${packs_list[@]}"; do
			if [[ "$package_name" == *"*"* ]]; then
				log_debug "Processing wildcard pattern: $package_name"
				local packages
				packages=$(dpkg-query -W -f='${binary:Package}\n' "${package_name}" 2>/dev/null | grep -v ' ')

				if [[ -z "$packages" ]]; then
					print_success "No installed packages found matching: $package_name"
					continue
				fi

				log_debug "matched packages: $packages"
				for package in $packages; do
					local retry_count=0
					local max_retries=5
					local remove_success=false
					while [[ "$retry_count" -lt "$max_retries" && "$remove_success" == false ]]; do
						retry_count=$((retry_count + 1))
						print_msg "Removing package: $package"
						dpkg --configure -a >/dev/null 2>&1

						apt autoremove "$package" -y 2>&1 | while IFS= read -r line; do
							echo "$line"
							if [[ "${line,,}" == *"removing"* ]]; then
								progress_phase "cleanup" 50 "Removing $package..."
							fi
						done

						if ! dpkg -s "$package" >/dev/null 2>&1; then
							print_success "Successfully removed package: $package"
							remove_success=true
						else
							print_warn "Failed to remove package: ${package}. Trying again...($retry_count)"
						fi
					done
				done
			else
				if dpkg -s "$package_name" >/dev/null 2>&1; then
					local retry_count=0
					local max_retries=5
					local remove_success=false
					while [[ "$retry_count" -lt "$max_retries" && "$remove_success" == false ]]; do
						retry_count=$((retry_count + 1))
						print_msg "Removing package: $package_name"
						dpkg --configure -a >/dev/null 2>&1

						apt autoremove "$package_name" -y 2>&1 | while IFS= read -r line; do
							echo "$line"
							if [[ "${line,,}" == *"removing"* ]]; then
								progress_phase "cleanup" 50 "Removing $package_name..."
							fi
						done

						if ! dpkg -s "$package_name" >/dev/null 2>&1; then
							print_success "Successfully removed package: $package_name"
							remove_success=true
						else
							print_warn "Failed to remove package: ${package_name}. Trying again... ($retry_count)"
						fi
					done
				else
					print_success "Package $package_name is not installed."
				fi
			fi
		done
	fi
}

