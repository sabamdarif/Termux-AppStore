	for arg in "$@"; do
		if [[ "$arg" == "--just" ]]; then
			just_run=true
		else
			# Safely split space-separated strings
			read -ra split_args <<<"$arg"
			filtered_args+=("${split_args[@]}")
		fi
	done

	if [[ "$just_run" == true ]]; then
		local args
		printf -v args "%q " "${filtered_args[@]}"
