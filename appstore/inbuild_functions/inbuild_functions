function _pd_package_install_and_check_internal() {
	log_debug "Starting distro package installation for: $*"
	progress_phase "install" 0 "Preparing distro packages: $*"

	_pd_update_sys_internal

	# shellcheck disable=SC2206
	local packs_list=($@)

	if [[ "$SELECTED_DISTRO" == "debian" ]] || [[ "$SELECTED_DISTRO" == "ubuntu" ]]; then
		local all_packages=()
		for package_name in "${packs_list[@]}"; do
			if [[ "$package_name" == *"*"* ]]; then
				local packages
				packages=$(apt-cache pkgnames 2>/dev/null | grep -E "^${package_name//\*/.*}$" | sort -u)
				for package in $packages; do
					all_packages+=("$package")
				done
			else
				all_packages+=("$package_name")
			fi
		done

		for package in "${all_packages[@]}"; do
			local retry_count=0
			local max_retries=5
			local install_success=false

			while [[ "$retry_count" -lt "$max_retries" && "$install_success" == false ]]; do
				retry_count=$((retry_count + 1))
				print_msg "Installing distro package: $package"

				apt install "$package" -y 2>&1 | while IFS= read -r line; do
					echo "$line"
					if [[ "${line,,}" == *"get:"* ]]; then
						progress_phase "install" 20 "Downloading $package..."
					elif [[ "${line,,}" == *"unpacking"* ]]; then
						progress_phase "install" 50 "Unpacking $package..."
					elif [[ "${line,,}" == *"setting up"* ]]; then
						progress_phase "install" 80 "Setting up $package..."
					fi
				done

				if dpkg -s "$package" >/dev/null 2>&1; then
					print_success "Successfully installed distro package: $package"
					install_success=true
				else
					print_warn "Failed to install distro package: ${package}. Trying again... ($retry_count)"
					dpkg --configure -a 2>/dev/null
					apt --fix-broken install -y 2>/dev/null
					apt install --fix-missing -y 2>/dev/null
				fi
			done
		done

	elif [[ "$SELECTED_DISTRO" == "arch" ]]; then
		local all_packages=()
		for package_name in "${packs_list[@]}"; do
			if [[ "$package_name" == *"*"* ]]; then
				local packages
				packages=$(pacman -Ssq 2>/dev/null | grep -E "^${package_name//\*/.*}$")
				for package in $packages; do
					all_packages+=("$package")
				done
			else
				all_packages+=("$package_name")
			fi
		done

		for package in "${all_packages[@]}"; do
			local retry_count=0
			local max_retries=5
			local install_success=false

			while [[ "$retry_count" -lt "$max_retries" && "$install_success" == false ]]; do
				retry_count=$((retry_count + 1))
				rm -f /var/lib/pacman/db.lck
				print_msg "Installing distro package: $package"

				pacman -S --noconfirm "$package" 2>&1 | while IFS= read -r line; do
					echo "$line"
					if [[ "${line,,}" == *"downloading"* ]]; then
						progress_phase "install" 20 "Downloading $package..."
					elif [[ "${line,,}" == *"checking"* ]]; then
						progress_phase "install" 50 "Checking $package..."
					elif [[ "${line,,}" == *"installing"* ]]; then
						progress_phase "install" 80 "Installing $package..."
					fi
				done

				if pacman -Qi "$package" >/dev/null 2>&1; then
					print_success "Successfully installed distro package: $package"
					install_success=true
				else
					print_warn "Failed to install distro package: ${package}. Trying again... ($retry_count)"
				fi
			done
		done

	elif [[ "$SELECTED_DISTRO" == "fedora" ]]; then
		local all_packages=()
		for package_name in "${packs_list[@]}"; do
			if [[ "$package_name" == *"*"* ]]; then
				local packages
				packages=$(dnf list available -q 2>/dev/null | awk '{print $1}' | cut -d'.' -f1 | grep -E "^${package_name//\*/.*}$")
				for package in $packages; do
					all_packages+=("$package")
				done
			else
				all_packages+=("$package_name")
			fi
		done

		for package in "${all_packages[@]}"; do
			local retry_count=0
			local max_retries=5
			local install_success=false

			while [[ "$retry_count" -lt "$max_retries" && "$install_success" == false ]]; do
				retry_count=$((retry_count + 1))
				print_msg "Installing distro package: $package"

				dnf install -y "$package" 2>&1 | while IFS= read -r line; do
					echo "$line"
					if [[ "${line,,}" == *"downloading"* ]]; then
						progress_phase "install" 20 "Downloading $package..."
					elif [[ "${line,,}" == *"running transaction"* ]]; then
						progress_phase "install" 80 "Installing $package..."
					fi
				done

				if rpm -q "$package" >/dev/null 2>&1; then
					print_success "Successfully installed distro package: $package"
					install_success=true
				else
					print_warn "Failed to install distro package: ${package}. Trying again... ($retry_count)"
				fi
			done
		done
	fi
	progress_phase "install" 100 "Distro package installation complete"
}

