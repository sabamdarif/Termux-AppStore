function pd_package_install_and_check() {
	local just_run=false
	local filtered_args=()

	for arg in "$@"; do
		if [[ "$arg" == "--just" ]]; then
			just_run=true
		else
			# Safely split space-separated strings
			read -ra split_args <<<"$arg"
			filtered_args+=("${split_args[@]}")
		fi
	done

	if [[ "$just_run" == true ]]; then
		local args
		printf -v args "%q " "${filtered_args[@]}"
		distro_run "_pd_package_install_and_check_internal $args"
	else
		"$SELECTED_DISTRO" install "${filtered_args[@]}" -y
	fi
}

