function check_termux() {
	if [ ! -f /system/build.prop ]; then
		echo "[☓] Not running on Android."
		exit 1
	fi

	local tracer_pid
	tracer_pid=$(grep TracerPid "/proc/$$/status" | cut -d $'\t' -f 2)
	if [ "$tracer_pid" != "0" ]; then
		local tracer_name
		tracer_name=$(grep Name "/proc/${tracer_pid}/status" | cut -d $'\t' -f 2)
		if [ "$tracer_name" = "proot" ]; then
			echo "[☓] Must not be executed under PRoot."
			exit 1
		fi
	fi

	if [[ -z "$TERMUX_PREFIX" || "$TERMUX_PREFIX" != *"/com.termux/"* ]]; then
		echo "[☓] Please run this script inside Termux."
		exit 1
	fi
}

function wait_for_keypress() {
