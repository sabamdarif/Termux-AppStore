# ==================== PROGRESS SYSTEM ====================
# These helpers are the only way scripts should emit progress.
# All output goes to stderr so it never pollutes stdout.
# Tokens are only emitted when PROGRESS_ENABLED=1 (set by Python).

PROGRESS_ENABLED=${PROGRESS_ENABLED:-0}

_progress_emit() {
	[[ "$PROGRESS_ENABLED" == "1" ]] && echo "$1" >&2
}

progress_report() {
	# Usage: progress_report PERCENT "Message"
	local percent="$1"
	local message="${2:-Working...}"
	_progress_emit "__PROGRESS__ ${percent}|${message}"
}

progress_phase() {
	# Usage: progress_phase PHASE_NAME PERCENT_IN_PHASE "Message"
	local phase="$1"
	local pct="${2:-0}"
	local message="${3:-}"
	_progress_emit "__PHASE__ ${phase}|${pct}|${message}"
}

progress_done() {
	_progress_emit "__DONE__"
}

progress_error() {
	_progress_emit "__ERROR__ ${1:-Unknown error}"
}
# ==================== END PROGRESS SYSTEM ====================

# ==================== FAILURE / LIFECYCLE ====================
# The Python runner enables `set -Eeo pipefail` and calls __appstore_begin
# right after sourcing this file, then __appstore_end at the very end of the
# script. Any unhandled command failure trips the ERR trap, which emits an
# __ERROR__ token and exits non-zero so the app store never falsely reports
# success. __DONE__ is emitted only when the script reaches the end cleanly.

__APPSTORE_FAILED=0
__APPSTORE_ERR_REPORTED=0

_appstore_err_trap() {
	local ec=$?
	local cmd=$BASH_COMMAND
	local line=${BASH_LINENO[0]:-?}
	__APPSTORE_FAILED=1
	# If print_failed already emitted a meaningful __ERROR__, don't clobber
	# it with a generic one — just abort.
	if [[ "$__APPSTORE_ERR_REPORTED" != "1" ]]; then
		progress_error "Step failed at line ${line} (exit ${ec}): ${cmd}"
	fi
	echo "[☓] Command failed (exit ${ec}) at line ${line}: ${cmd}"
	log_error "ERR trap: line ${line} exit ${ec}: ${cmd}"
	exit "$ec"
}

# Call after sourcing this file to arm failure handling.
__appstore_begin() {
	trap '_appstore_err_trap' ERR
}

# Call at the very end of a script; emits __DONE__ only on a clean run.
__appstore_end() {
	if [[ "$__APPSTORE_FAILED" == "0" ]]; then
		progress_done
	fi
}

# Run a command whose failure is non-fatal (best-effort). Use sparingly.
soft_run() {
	"$@" || return 0
}
# ==================== END FAILURE / LIFECYCLE ====================

